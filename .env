APP_NAME=Local AI Document Assistant
APP_VERSION=0.1.0
DATA_DIR=./data
CHUNK_SIZE=5000
CHUNK_OVERLAP=100
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
TOP_K=5
MIN_SOURCE_SIMILARITY_SCORE=0.35
RETRIEVAL_CANDIDATES=15
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
EVALUATION_QUESTIONS_FILE=./test_questions/eval_questions.json
EVALUATION_OUTPUT_FILE=./test_questions/eval_results.json
EVALUATION_TOP_K=5
LOG_LEVEL=INFO
